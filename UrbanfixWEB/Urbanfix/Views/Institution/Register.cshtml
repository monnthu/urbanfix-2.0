@model Urbanfix.Models.InstitutionRegistrationViewModel
@using Urbanfix.Models
@{
    ViewData["Title"] = "Registro institucional";
    var currentApplication = ViewBag.CurrentApplication as InstitutionApplication;
    var categories = Enum.GetValues<ReportCategory>();
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <h1 class="display-6 mb-2">Registro institucional</h1>
        <p class="text-muted mb-4">
            Solicita verificacion para recibir reportes por categoria y zona de servicio.
        </p>

        @if (TempData["Success"] is string successMessage)
        {
            <div class="alert alert-success">@successMessage</div>
        }

        @if (TempData["Error"] is string errorMessage)
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        @if (currentApplication is not null)
        {
            <div class="alert alert-info">
                Estado actual: <strong>@currentApplication.Status.GetDisplayName()</strong>
                @if (!string.IsNullOrWhiteSpace(currentApplication.ReviewNote))
                {
                    <span>- @currentApplication.ReviewNote</span>
                }
            </div>
        }

        <form asp-action="Register" method="post" enctype="multipart/form-data" novalidate>
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="InstitutionName" class="form-label"></label>
                <input asp-for="InstitutionName" class="form-control" />
                <span asp-validation-for="InstitutionName" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="OfficialEmail" class="form-label"></label>
                    <input asp-for="OfficialEmail" class="form-control" autocomplete="email" />
                    <span asp-validation-for="OfficialEmail" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="OfficialDomain" class="form-label"></label>
                    <input asp-for="OfficialDomain" class="form-control" placeholder="alcaldia.gob" />
                    <span asp-validation-for="OfficialDomain" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Department" class="form-label"></label>
                <input asp-for="Department" class="form-control" placeholder="Obras publicas, emergencias, limpieza..." />
                <span asp-validation-for="Department" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ServiceZoneCode" class="form-label"></label>
                <select asp-for="ServiceZoneCode" asp-items="Model.ZoneOptions" class="form-select">
                    <option value="">Selecciona una zona</option>
                </select>
                <span asp-validation-for="ServiceZoneCode" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Categorias cubiertas</label>
                <div class="row g-2">
                    @foreach (var category in categories)
                    {
                        var selected = Model.CoverageCategories.Contains(category);
                        <div class="col-md-6">
                            <div class="form-check border rounded p-3 h-100">
                                @if (selected)
                                {
                                    <input class="form-check-input ms-0 me-2"
                                           type="checkbox"
                                           name="CoverageCategories"
                                           value="@((int)category)"
                                           id="category-@category"
                                           checked="checked" />
                                }
                                else
                                {
                                    <input class="form-check-input ms-0 me-2"
                                           type="checkbox"
                                           name="CoverageCategories"
                                           value="@((int)category)"
                                           id="category-@category" />
                                }
                                <label class="form-check-label" for="category-@category">
                                    @category.GetDisplayName()
                                </label>
                            </div>
                        </div>
                    }
                </div>
                <span asp-validation-for="CoverageCategories" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ProofDocument" class="form-label"></label>
                <input asp-for="ProofDocument" class="form-control" type="file" accept=".pdf,image/jpeg,image/png,image/webp" />
                <div class="form-text">Sube una carta, credencial o documento oficial. Maximo 10 MB.</div>
                <span asp-validation-for="ProofDocument" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100">Enviar solicitud</button>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
